<MudDrawer @bind-Open="_appState.IsNavOpen"
           ClipMode="DrawerClipMode.Never"
           Elevation="2">
    <MudDrawerHeader Class="d-flex align-center">
        @if (_appState.IsDark)
        {
            <MudImage Src="/images/header-logo-dark.png"  Width="170" Height="60" />
        }
        else
        {
            <MudImage Src="/images/header-logo.png"  Width="170" Height="60"/>
        }
    </MudDrawerHeader>
    <MudNavMenu Margin="Margin.Dense" Color="Color.Primary" Rounded="true" Class="pa-2">
        @if (_appState.NavMenuItems == null)
        {
            <p><em>Cargando...</em></p>
        }
        else
        {
            <NavItemMenu NavMenuItems="_appState.NavMenuItems" NavTo="NavTo" />
        }
       @*  <LogoutButton></LogoutButton> *@
    </MudNavMenu>
</MudDrawer>

