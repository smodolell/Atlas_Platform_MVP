@attribute [Route(PageRoute.AsistenciasPage)]
@attribute [AccessPoint(AppMenu.MenuAsistencias, "Asistencias")]
@using Atlas.Admin.Pages.Asistencias.Components

<PageHeader Title="Asistencias" Icon="@AppMenu.MenuAsistenciasIcon">
    <MudBreadcrumbs Items="_breadcrumbItems"></MudBreadcrumbs>
</PageHeader>

<MudPaper Elevation="2" Class="pa-4 mt-4">
    <AsistenciaList />
</MudPaper>

@code {
    private readonly List<BreadcrumbItem> _breadcrumbItems =
    [
        new BreadcrumbItem("Inicio", href: "/"),
        new BreadcrumbItem("Asistencias", href: null, disabled: true)
    ];
}
