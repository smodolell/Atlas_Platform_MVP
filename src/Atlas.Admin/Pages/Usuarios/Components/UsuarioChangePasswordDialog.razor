@using Atlas.Client.Services
@using Atlas.Shared.Accounts.Usuarios
@inject IAccountsApi _accountsApi

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" />
            Cambiar Contraseña — @UserName
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit">
            <FluentValidator />
            <ValidationSummary />
            <MudTextField Label="Nueva Contraseña"
                          @bind-Value="_model.NewPassword"
                          For="@(() => _model.NewPassword)"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Class="mb-4" />
            <MudTextField Label="Confirmar Nueva Contraseña"
                          @bind-Value="_model.ConfirmNewPassword"
                          For="@(() => _model.ConfirmNewPassword)"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Class="mb-2" />
            <button type="submit" id="submit-pwd-form" hidden></button>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton ButtonType="ButtonType.Submit"
                   HtmlTag="label"
                   for="submit-pwd-form"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Guardando...</MudText>
            }
            else
            {
                <MudText>Cambiar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int UsuarioId { get; set; }
    [Parameter] public string UserName { get; set; } = string.Empty;

    private UserChangePasswordDto _model = new();
    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;
    private bool _isSaving;

    protected override void OnInitialized()
    {
        _model.UserId = UsuarioId;
        _editContext = new EditContext(_model);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += (s, e) => _messageStore.Clear(e.FieldIdentifier);
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;
        _messageStore?.Clear();

        try
        {
            await _accountsApi.ChangeUserPasswordByAdmin(_model);
            _snackbarService.Add("Contraseña actualizada correctamente", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (YggdrasilApiException ex)
        {
            // _messageStore?.MapErrors(ex, _model, _editContext!);
            _snackbarService.Add("Por favor revise los errores de validación", Severity.Warning);
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
