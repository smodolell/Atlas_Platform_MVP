
@using Atlas.Shared.Accounts.Usuarios
@inject IAccountsApi _accountsApi


<MudPaper Elevation="2" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudTextField @bind-Value="_searchQuery"
                      Placeholder="Buscar usuario..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Clearable="true"
                      OnClearButtonClick="OnSearchCleared"
                      Style="max-width:320px" />
        <MudButton StartIcon="@Icons.Material.Filled.Search"
                   Variant="Variant.Filled"
                   Color="Color.Default"
                   OnClick="LoadData"
                   Size="Size.Small">
            Buscar
        </MudButton>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.PersonAdd"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="OpenCreateDialog">
            Nuevo Usuario
        </MudButton>
    </MudStack>

    <MudDataGrid T="UsuarioListItemDto"
                 Items="_usuarios"
                 Loading="_isLoading"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 SortMode="SortMode.None">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.UserName" Title="Usuario" />
            <PropertyColumn Property="x => x.NombreCompleto" Title="Nombre Completo" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <PropertyColumn Property="x => x.Telefono" Title="Teléfono" />
            <TemplateColumn Title="Acciones" CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Title="Editar"
                                   OnClick="@(() => OpenEditDialog(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts"
                                   Color="Color.Secondary"
                                   Size="Size.Small"
                                   Title="Asignar Roles"
                                   OnClick="@(() => OpenRolesDialog(context.Item.Id, context.Item.UserName ?? string.Empty))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Lock"
                                   Color="Color.Warning"
                                   Size="Size.Small"
                                   Title="Cambiar Contraseña"
                                   OnClick="@(() => OpenChangePasswordDialog(context.Item.Id, context.Item.UserName ?? string.Empty))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Title="Eliminar"
                                   OnClick="@(() => ConfirmDelete(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>No se encontraron usuarios.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando...</MudText>
        </LoadingContent>
    </MudDataGrid>

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
        <MudText Typo="Typo.body2">Total: @_totalCount registros</MudText>
        <MudSpacer />
        <MudPagination Count="_totalPages"
                       Selected="_currentPage"
                       SelectedChanged="OnPageChanged"
                       Color="Color.Primary"
                       ShowFirstButton="true"
                       ShowLastButton="true" />
    </MudStack>
</MudPaper>

@code {
    private List<UsuarioListItemDto> _usuarios = [];
    private string _searchQuery = string.Empty;
    private bool _isLoading;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
           var response = await _accountsApi.GetUsuarios(_searchQuery,_currentPage,PageSize);
            if (response?.Data != null)
            {
                _usuarios = response.Data.Results ?? [];
                _totalCount = response.Data.TotalCount;
                _totalPages = response.Data.TotalPages;
                if (_totalPages < 1) _totalPages = 1;
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar usuarios: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private async Task OnSearchCleared()
    {
        _searchQuery = string.Empty;
        _currentPage = 1;
        await LoadData();
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await _dialogService.ShowAsync<UsuarioFormDialog>("Nuevo Usuario", new DialogParameters(), new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        });
        var result = await dialog.Result;
        if (!result!.Canceled) await LoadData();
    }

    private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters { ["UsuarioId"] = id };
        var dialog = await _dialogService.ShowAsync<UsuarioFormDialog>("Editar Usuario", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        });
        var result = await dialog.Result;
        if (!result!.Canceled) await LoadData();
    }

    private async Task OpenRolesDialog(int id, string userName)
    {
        var parameters = new DialogParameters
        {
            ["UsuarioId"] = id,
            ["UserName"] = userName
        };
        var dialog = await _dialogService.ShowAsync<UsuarioRolesDialog>($"Roles — {userName}", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        });
        await dialog.Result;
    }

    private async Task OpenChangePasswordDialog(int id, string userName)
    {
        var parameters = new DialogParameters
        {
            ["UsuarioId"] = id,
            ["UserName"] = userName
        };
        var dialog = await _dialogService.ShowAsync<UsuarioChangePasswordDialog>($"Cambiar Contraseña — {userName}", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseButton = true
        });
        await dialog.Result;
    }

    private async Task ConfirmDelete(UsuarioListItemDto usuario)
    {
        var confirm = await _dialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"¿Deseas eliminar al usuario \"{usuario.UserName}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar",
            cancelText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (confirm == true)
            await DeleteUsuario(usuario.Id);
    }

    private async Task DeleteUsuario(int id)
    {
        try
        {
            await _accountsApi.DeleteUsuario(id);
            _snackbarService.Add("Usuario eliminado correctamente", Severity.Success);
            if (_usuarios.Count == 1 && _currentPage > 1)
                _currentPage--;
            await LoadData();
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        }
    }
}
