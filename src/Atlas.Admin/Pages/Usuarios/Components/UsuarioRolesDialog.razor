@using Atlas.Shared.Accounts.Usuarios
@inject IAccountsApi _accountsApi;

<MudDialog>
    <DialogContent>

        <div class="d-flex flex-column" style="max-height:300px;overflow:auto;">
            @foreach (var role in RoleList)
            {
                <MudCheckBox T="bool" @bind-Value="CheckedDic[role.Id]" Color="Color.Primary">@role.RolName</MudCheckBox>
            }
        </div>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" FullWidth="false"
                   Color="Color.Primary"
                   Size="Size.Medium"
                   ButtonType="ButtonType.Submit"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveSubmit">
            Guardar
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Default"
                   Size="Size.Medium"
                   OnClick="Close"
                   StartIcon="@Icons.Material.Filled.Close">
            Cerrar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public int UsuarioId { get; set; }


    private Dictionary<int, bool> CheckedDic = new Dictionary<int, bool>();
    private List<UsuarioRolDto> RoleList = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await _accountsApi.GetRolesByUsuarioId(UsuarioId);
        RoleList = result.Data!;
        foreach (var role in RoleList)
        {
            CheckedDic[role.Id] = role.Selected;
        }
    }

    private async Task SaveSubmit()
    {

        try
        {
            var result = await _accountsApi.SaveUsuarioRol(UsuarioId, CheckedDic);
            if (result.Success)
            {
                _snackbarService.Add(result.Message, Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _snackbarService.Add(result.Errors.FirstOrDefault() ?? "Error", Severity.Error);
            }

        }
        catch (Exception ex)
        {
            _snackbarService.Add(ex.Message, Severity.Error);
        }
    }
    private void Close() => MudDialog?.Cancel();
}
