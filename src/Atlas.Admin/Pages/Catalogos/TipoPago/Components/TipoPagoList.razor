@using Atlas.Shared.Catalogos
@using Atlas.Client.Services
@inject ICatalogosApi _catalogosApi

<MudDataGrid T="TipoPagoListItemDto"
             Outlined="true"
             Dense="true"
             Bordered="true"
             ServerData="GetTableData"
             FixedHeader="true"
             SortMode="SortMode.Single"
             @ref="_dataGridRef"
             Loading="_isLoading"
             Striped="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Tipos de Pago</MudText>
        <MudSpacer />
        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
            <MudTextField T="string"
                          ValueChanged="@(s => OnSearch(s))"
                          Placeholder="Buscar por nombre..."
                          Adornment="Adornment.Start"
                          Clearable="true"
                          Class="flex-grow-0"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Small" />
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
            <MudTooltip Text="Actualizar">
                <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                               Size="Size.Small"
                               Color="Color.Info"
                               OnClick="RefreshData"
                               Disabled="_isLoading" />
            </MudTooltip>
            <MudTooltip Text="Nuevo Tipo de Pago">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddClick"
                           Disabled="_isLoading">
                    Nuevo
                </MudButton>
            </MudTooltip>
        </MudStack>
    </ToolBarContent>

    <Columns>
        <PropertyColumn Property="x => x.NomTipoPago" Title="Nombre" StickyLeft="true" />
        <TemplateColumn Title="Activo" SortBy="x => x.Activo">
            <CellTemplate>
                <MudChip T="string"
                         Color="@(context.Item.Activo ? Color.Success : Color.Error)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @(context.Item.Activo ? "Activo" : "Inactivo")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Acciones" CellClass="d-flex justify-end" StickyRight="true">
            <CellTemplate>
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => EditClick(context.Item.Id))" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => ConfirmDelete(context.Item))" />
                    </MudTooltip>
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>

    <NoRecordsContent>
        <MudText>No se encontraron tipos de pago.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Cargando...</MudText>
    </LoadingContent>
</MudDataGrid>

@code {
    private MudDataGrid<TipoPagoListItemDto> _dataGridRef = null!;
    private bool _isLoading;
    private string? _searchText;

    private async Task<GridData<TipoPagoListItemDto>> GetTableData(GridState<TipoPagoListItemDto> gridState, CancellationToken cancellationToken)
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            var pageNumber = gridState.Page + 1;
            var sortBy = nameof(TipoPagoListItemDto.NomTipoPago);
            var sortDescending = false;

            var sortDef = gridState.SortDefinitions.FirstOrDefault();
            if (sortDef != null)
            {
                sortBy = sortDef.SortBy;
                sortDescending = sortDef.Descending;
            }

            var response = await _catalogosApi.GetTiposPagoAsync(
                _searchText, pageNumber, gridState.PageSize, sortBy, sortDescending, cancellationToken);

            return new GridData<TipoPagoListItemDto>
            {
                TotalItems = response.Data!.TotalCount,
                Items = response.Data!.Results
            };
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar tipos de pago: {ex.Message}", Severity.Error);
            return new GridData<TipoPagoListItemDto> { TotalItems = 0, Items = [] };
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void AddClick() => _navManager.NavigateTo(PageRoute.NewTipoPagoPage);

    private void EditClick(int id) => _navManager.NavigateTo($"{PageRoute.EditTipoPagoPage}/{id}");

    private async Task ConfirmDelete(TipoPagoListItemDto item)
    {
        var confirm = await _dialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"¿Deseas eliminar el tipo de pago \"{item.NomTipoPago}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar",
            cancelText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (confirm == true)
            await DeleteTipoPago(item.Id);
    }

    private async Task DeleteTipoPago(int id)
    {
        try
        {
            var response = await _catalogosApi.DeleteTipoPagoAsync(id);
            if (response.IsSuccessStatusCode)
            {
                _snackbarService.Add("Tipo de pago eliminado correctamente", Severity.Success);
                await RefreshData();
            }
            else
            {
                _snackbarService.Add("Error al eliminar el tipo de pago", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnSearch(string? text)
    {
        _searchText = text;
        await RefreshData();
    }

    private async Task RefreshData()
    {
        if (_dataGridRef != null)
            await _dataGridRef.ReloadServerData();
    }
}
