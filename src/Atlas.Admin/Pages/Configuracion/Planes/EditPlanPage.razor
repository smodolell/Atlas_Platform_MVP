@attribute [Route(PageRoute.EditPlanPage + "/{PlanId:int}")]
@attribute [AccessPoint(AppMenu.MenuConfiguracion, "Editar Plan",AccessPointType.Page)]
@using Atlas.Shared.Configuracion
@using Atlas.Client.Services
@using Atlas.Admin.Pages.Configuracion.Planes.Components
@inject IConfiguracionApi _configuracionApi


<PageHeader Title="Editar Producto" Icon="@Icons.Material.Filled.Edit">
    <MudBreadcrumbs Items="_breadcrumbItems"></MudBreadcrumbs>

</PageHeader>

<MudPaper Elevation="2" Class="pa-4 mt-4">
    @if (_isLoading)
    {
        <MudProgressCircular Indeterminate="true" Class="mt-5 mb-5 mx-auto" />
    }
    else if (_model == null)
    {
        <MudAlert Severity="Severity.Error">Plan no encontrado</MudAlert>
        <MudButton Variant="Variant.Outlined" Class="mt-3" OnClick="GoBack">Volver</MudButton>
    }
    else
    {
        <PlanForm Model="_model"
                      IsSaving="_isSaving"
                      OnValidSubmit="HandleSave"
                      OnCancel="GoBack" />
    }
</MudPaper>

@code {
    [Parameter]
    public int PlanId { get; set; }

    private PlanEditDto? _model;
    private bool _isSaving;
    private bool _isLoading = true;
    private readonly List<BreadcrumbItem> _breadcrumbItems = new()
{
        new BreadcrumbItem("Inicio", href: "/"),
        new BreadcrumbItem("Planes", href: PageRoute.PlanesPage),
        new BreadcrumbItem("Editar Plan", href: null, disabled: true)
    };
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await _configuracionApi.GetPlanByIdAsync(PlanId);
            if (response.Content?.Data != null)
            {
                _model = response.Content.Data;
            }
            else
            {
                _snackbarService.Add("Plan no encontrado.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSave(PlanEditDto model)
    {
        _isSaving = true;
        try
        {
            var response = await _configuracionApi.UpdatePlanAsync(PlanId, model);
            if (response.IsSuccessStatusCode)
            {
                _snackbarService.Add("Plan actualizado correctamente", Severity.Success);
                _navManager.NavigateTo(PageRoute.PlanesPage);
            }
            else
            {
                _snackbarService.Add("Error al actualizar el plan", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void GoBack()
    {
        _navManager.NavigateTo(PageRoute.PlanesPage);
    }
}
