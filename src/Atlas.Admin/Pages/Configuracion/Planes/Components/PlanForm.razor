@using Atlas.Shared.Configuracion
@inject ISelectListsApi _selectListsApi;

<EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit" autocomplete="off">
    <FluentValidator />
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField Label="Nombre"
                          @bind-Value="Model.NomPlan"
                          For="@(() => Model.NomPlan)"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField Label="Descripción"
                          @bind-Value="Model.Descripcion"
                          For="@(() => Model.Descripcion)"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4" />
        </MudItem>
        <MudItem xs="12" sm="6">
            @if (_listServicios == null)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="40px" />
            }
            else
            {
                <MudSelect T="int" Label="Servicio" @bind-Value="Model.ServicioId" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int" Value="0">[Seleccione]</MudSelectItem>
                    @foreach (var item in _listServicios)
                    {
                        <MudSelectItem T="int" Value="@Convert.ToInt32(item.Value)">@item.Text</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudItem>
        <MudItem xs="12" sm="6">
            @if (_listPeriodicidad == null)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="40px" />
            }
            else
            {
                <MudSelect T="int" Label="Periodicidad" @bind-Value="Model.PeriodicidadId" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int" Value="0">[Seleccione]</MudSelectItem>
                    @foreach (var item in _listPeriodicidad)
                    {
                        <MudSelectItem T="int" Value="@Convert.ToInt32(item.Value)">@item.Text</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField Label="Precio"
                             @bind-Value="Model.Precio"
                             For="@(() => Model.Precio)"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Format="C2"
                             Step="0.01M"
                             Class="mb-4" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField Label="Cupo Máximo"
                             @bind-Value="Model.CupoMaximo"
                             For="@(() => Model.CupoMaximo)"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Step="1"
                             Class="mb-4" />
        </MudItem>
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Tipo de plan</MudText>
            <MudRadioGroup T="string" Value="_tipoPlan" ValueChanged="OnTipoPlanChanged">
                <MudRadio T="string" Value="@("libre")" Color="Color.Primary">Libre</MudRadio>
                <MudRadio T="string" Value="@("programado")" Color="Color.Primary">Programado</MudRadio>
                <MudRadio T="string" Value="@("ticket")" Color="Color.Primary">Ticket</MudRadio>
            </MudRadioGroup>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSwitch @bind-Value="Model.Activo" Label="Activo" Color="Color.Primary" />
        </MudItem>
    </MudGrid>
    
    <div class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="mr-2" Disabled="IsSaving">
            @if (IsSaving)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Guardando...</MudText>
            }
            else
            {
                <MudText>Guardar</MudText>
            }
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="OnCancel">Cancelar</MudButton>
    </div>
</EditForm>

@code {
    [Parameter]
    public PlanEditDto Model { get; set; } = new();

    [Parameter]
    public EventCallback<PlanEditDto> OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsSaving { get; set; }

    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;
    private List<SelectListItemDto>? _listPeriodicidad;
    private List<SelectListItemDto>? _listServicios;
    private string _tipoPlan = "libre";

    protected override async Task OnInitializedAsync()
    {
        _editContext = new EditContext(Model);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnFieldChanged += (s, e) => _messageStore.Clear(e.FieldIdentifier);

        var tareas = new List<Task>();
        if (_listPeriodicidad == null)
            tareas.Add(_selectListsApi.GetPeriodicidadSelectListAsync().ContinueWith(t => _listPeriodicidad = t.Result.Data));
        if (_listServicios == null)
            tareas.Add(_selectListsApi.GetServicioSelectListAsync().ContinueWith(t => _listServicios = t.Result.Data));
        await Task.WhenAll(tareas);

        SyncTipoPlanFromModel();
    }

    protected override void OnParametersSet()
    {
        if (_editContext != null && _editContext.Model != Model)
        {
            _editContext = new EditContext(Model);
            _messageStore = new ValidationMessageStore(_editContext);
            _editContext.OnFieldChanged += (s, e) => _messageStore.Clear(e.FieldIdentifier);
        }
        SyncTipoPlanFromModel();
    }

    private void SyncTipoPlanFromModel()
    {
        if (Model.EsProgramado) _tipoPlan = "programado";
        else if (Model.EsTicket) _tipoPlan = "ticket";
        else _tipoPlan = "libre";
    }

    private void OnTipoPlanChanged(string value)
    {
        _tipoPlan = value;
        Model.EsLibre = value == "libre";
        Model.EsProgramado = value == "programado";
        Model.EsTicket = value == "ticket";
    }

    private async Task HandleSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            _messageStore?.Clear();
            await OnValidSubmit.InvokeAsync(Model);
        }
    }
}
