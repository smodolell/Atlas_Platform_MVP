@using Atlas.Shared.Configuracion
@using Atlas.Client.Services
@inject IConfiguracionApi _configuracionApi
@inject ISelectListsApi _selectListsApi;

<MudDrawer @bind-Open="@_openFilter" Fixed="false" Width="350px" Anchor="Anchor.Right" Elevation="1" Variant="@DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Filtros de búsqueda</MudText>
    </MudDrawerHeader>
    <MudDrawerContainer>
        <MudGrid Spacing="2" Class="pa-4">
            <MudItem xs="12">
                <MudSelect T="int?" Label="Servicio" @bind-Value="_servicioId" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int?" Value="@((int?)null)">[Todos]</MudSelectItem>
                    @if (_listServicios != null)
                    {
                        @foreach (var item in _listServicios)
                        {
                            <MudSelectItem T="int?" Value="@((int?)Convert.ToInt32(item.Value))">@item.Text</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="int?" Label="Periodicidad" @bind-Value="_periodicidadId" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int?" Value="@((int?)null)">[Todas]</MudSelectItem>
                    @if (_listPeriodicidad != null)
                    {
                        @foreach (var item in _listPeriodicidad)
                        {
                            <MudSelectItem T="int?" Value="@((int?)Convert.ToInt32(item.Value))">@item.Text</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudButtonGroup Size="Size.Small" Variant="Variant.Filled">
                    <MudButton Color="Color.Secondary" OnClick="OnCancelFilter">Cancelar</MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Clear" OnClick="OnClearFilter" Disabled="_isLoading">Limpiar</MudButton>
                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Search" OnClick="RefreshData" Disabled="_isLoading">Filtrar</MudButton>
                </MudButtonGroup>
            </MudItem>
        </MudGrid>
    </MudDrawerContainer>
</MudDrawer>

<MudDataGrid T="PlanListItemDto"
             Outlined="true"
             Dense="true"
             Bordered="true"
             ServerData="GetTableData"
             FixedHeader="true"
             SortMode="SortMode.Single"
             @ref="_dataGridRef"
             Loading="_isLoading"
             Striped="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Listados de Planes</MudText>
        <MudSpacer />
        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
            <MudTextField T="string"
                          ValueChanged="@(s => OnSearch(s))"
                          Placeholder="Buscar por nombre o descripción..."
                          Adornment="Adornment.Start"
                          Clearable="true"
                          Class="flex-grow-0"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Small" />
            <MudIconButton Icon="@Icons.Material.Outlined.FilterAlt"
                           Class="align-self-end pa-1"
                           Size="Size.Medium"
                           OnClick="OnFilterClicked" />
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
            <MudTooltip Text="Actualizar">
                <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                               Size="Size.Small"
                               Color="Color.Info"
                               OnClick="RefreshData"
                               Disabled="_isLoading" />
            </MudTooltip>
            <MudTooltip Text="Nuevo Plan">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.Add"
                           OnClick="AddClick"
                           Disabled="_isLoading">
                    Nuevo Plan
                </MudButton>
            </MudTooltip>
        </MudStack>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.NomServicio" Title="Servicio" StickyLeft="true" />
        <PropertyColumn Property="x => x.NomPlan" Title="Nombre" />
     
        @* <PropertyColumn Property="x => x.Descripcion" Title="Descripción" /> *@
        <TemplateColumn Title="Precio" SortBy="x => x.Precio">
            <CellTemplate>
                <MudText>@context.Item.Precio.ToString("C2")</MudText>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.NomPeriodicidad" Title="Periodicidad" />
        <PropertyColumn Property="x => x.CupoMaximo" Title="Cupo Máximo" />
        <TemplateColumn Title="Tipo">
            <CellTemplate>
                @{
                    var (label, color) = context.Item switch
                    {
                        { EsProgramado: true } => ("Programado", Color.Info),
                        { EsTicket: true } => ("Ticket", Color.Warning),
                        _ => ("Libre", Color.Default)
                    };
                }
                <MudChip T="string" Color="color" Size="Size.Small" Variant="Variant.Outlined">@label</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Estado" SortBy="x => x.Activo">
            <CellTemplate>
                <MudChip T="string"
                         Color="@(context.Item.Activo ? Color.Success : Color.Error)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @(context.Item.Activo ? "Activo" : "Inactivo")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Acciones" CellClass="d-flex justify-end" StickyRight="true">
            <CellTemplate>
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => EditClick(context.Item.Id))" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => ConfirmDelete(context.Item))" />
                    </MudTooltip>
                </MudStack>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent><MudText>No se encontraron planes.</MudText></NoRecordsContent>
    <LoadingContent><MudText>Cargando...</MudText></LoadingContent>
</MudDataGrid>

@code {
    private MudDataGrid<PlanListItemDto> _dataGridRef = null!;
    private string? _searchText;
    private int? _periodicidadId;
    private int? _servicioId;
    private List<SelectListItemDto>? _listPeriodicidad;
    private List<SelectListItemDto>? _listServicios;
    private bool _isLoading;
    private bool _openFilter;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            _selectListsApi.GetPeriodicidadSelectListAsync().ContinueWith(t => _listPeriodicidad = t.Result.Data),
            _selectListsApi.GetServicioSelectListAsync().ContinueWith(t => _listServicios = t.Result.Data)
        );
    }

    private async Task<GridData<PlanListItemDto>> GetTableData(GridState<PlanListItemDto> gridState, CancellationToken cancellationToken)
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            var sortDef = gridState.SortDefinitions.FirstOrDefault();
            var sortBy = sortDef?.SortBy ?? nameof(PlanListItemDto.NomPlan);
            var sortDesc = sortDef?.Descending ?? false;

            var paginatedList = await _configuracionApi.GetPlanesAsync(
                _searchText, gridState.Page + 1, gridState.PageSize,
                sortBy, sortDesc, _periodicidadId, _servicioId);

            return new GridData<PlanListItemDto>
            {
                TotalItems = paginatedList.Data!.TotalCount,
                Items = paginatedList.Data!.Results
            };
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar planes: {ex.Message}", Severity.Error);
            return new GridData<PlanListItemDto> { TotalItems = 0, Items = Enumerable.Empty<PlanListItemDto>() };
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void AddClick() => _navManager.NavigateTo(PageRoute.NewPlanPage);

    private void EditClick(int id) => _navManager.NavigateTo($"{PageRoute.EditPlanPage}/{id}");

    private async Task ConfirmDelete(PlanListItemDto producto)
    {
        var confirm = await _dialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"¿Deseas eliminar el plan \"{producto.NomPlan}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar", cancelText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (confirm == true)
            await DeletePlan(producto.Id);
    }

    private async Task DeletePlan(int id)
    {
        // TODO: implementar cuando el endpoint de borrar plan esté listo
        await Task.CompletedTask;
    }

    private async Task RefreshData()
    {
        if (_dataGridRef != null)
            await _dataGridRef.ReloadServerData();
    }

    private async Task OnClearFilter()
    {
        _searchText = null;
        _periodicidadId = null;
        _servicioId = null;
        _openFilter = false;
        await RefreshData();
    }

    private void OnFilterClicked() => _openFilter = true;

    private async Task OnCancelFilter()
    {
        _openFilter = false;
        await RefreshData();
    }

    private async Task OnSearch(string? text)
    {
        _searchText = text;
        await RefreshData();
    }
}
