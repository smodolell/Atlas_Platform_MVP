@attribute [Route(PageRoute.NewPlanPage)]
@attribute [AccessPoint(AppMenu.MenuConfiguracion, "Nuevo Plan")]
@using Atlas.Shared.Configuracion
@using Atlas.Client.Services
@using Atlas.Admin.Pages.Configuracion.Planes.Components
@inject IConfiguracionApi _configuracionApi


<PageHeader Title="Nuevo Plan" Icon="@Icons.Material.Filled.AddBox" >
    <MudBreadcrumbs Items="_breadcrumbItems"></MudBreadcrumbs>
</PageHeader>

<MudPaper Elevation="2" Class="pa-4 mt-4">
    <PlanForm Model="_model"
                  IsSaving="_isSaving"
                  OnValidSubmit="HandleSave"
                  OnCancel="GoBack" />
</MudPaper>

@code {

    private PlanEditDto _model = new();
    private bool _isSaving;
    private readonly List<BreadcrumbItem> _breadcrumbItems = new()
{
        new BreadcrumbItem("Inicio", href: "/"),
        new BreadcrumbItem("Productos", href: PageRoute.PlanesPage),
        new BreadcrumbItem("Nuevo Producto", href: null, disabled: true)
    };
    private async Task HandleSave(PlanEditDto model)
    {
        _isSaving = true;
        try
        {
            var response = await _configuracionApi.CreatePlanAsync(model);
            if (response.IsSuccessStatusCode)
            {
                _snackbarService.Add("Plan creado correctamente", Severity.Success);
                _navManager.NavigateTo(PageRoute.PlanesPage);
            }
            else
            {
                _snackbarService.Add("Error al crear el plan", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void GoBack()
    {
        _navManager.NavigateTo(PageRoute.PlanesPage);
    }
}
