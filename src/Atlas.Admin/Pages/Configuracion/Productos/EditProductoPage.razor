@attribute [Route(PageRoute.EditProductoPage + "/{ProductoId:int}")]
@attribute [AccessPoint(AppMenu.MenuConfiguracion, "Editar Producto",AccessPointType.Page)]
@using Atlas.Shared.Configuracion
@using Atlas.Client.Services
@using Atlas.Admin.Pages.Configuracion.Productos.Components
@inject IConfiguracionApi _configuracionApi


<PageHeader Title="Editar Producto" Icon="@Icons.Material.Filled.Edit">
    <MudBreadcrumbs Items="_breadcrumbItems"></MudBreadcrumbs>

</PageHeader>

<MudPaper Elevation="2" Class="pa-4 mt-4">
    @if (_isLoading)
    {
        <MudProgressCircular Indeterminate="true" Class="mt-5 mb-5 mx-auto" />
    }
    else if (_model == null)
    {
        <MudAlert Severity="Severity.Error">Producto no encontrado</MudAlert>
        <MudButton Variant="Variant.Outlined" Class="mt-3" OnClick="GoBack">Volver</MudButton>
    }
    else
    {
        <ProductoForm Model="_model"
                      IsSaving="_isSaving"
                      OnValidSubmit="HandleSave"
                      OnCancel="GoBack" />
    }
</MudPaper>

@code {
    [Parameter]
    public int ProductoId { get; set; }

    private ProductoEditDto? _model;
    private bool _isSaving;
    private bool _isLoading = true;
    private readonly List<BreadcrumbItem> _breadcrumbItems = new()
{
        new BreadcrumbItem("Inicio", href: "/"),
        new BreadcrumbItem("Productos", href: PageRoute.ProductosPage),
        new BreadcrumbItem("Editar Producto", href: null, disabled: true)
    };
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await _configuracionApi.GetProductoByIdAsync(ProductoId);
            if (response.Content?.Data != null)
            {
                _model = response.Content.Data;
            }
            else
            {
                _snackbarService.Add("Producto no encontrado.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSave(ProductoEditDto model)
    {
        _isSaving = true;
        try
        {
            var response = await _configuracionApi.UpdateProductoAsync(ProductoId, model);
            if (response.IsSuccessStatusCode)
            {
                _snackbarService.Add("Producto actualizado correctamente", Severity.Success);
                _navManager.NavigateTo(PageRoute.ProductosPage);
            }
            else
            {
                _snackbarService.Add("Error al actualizar el producto", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void GoBack()
    {
        _navManager.NavigateTo(PageRoute.ProductosPage);
    }
}
