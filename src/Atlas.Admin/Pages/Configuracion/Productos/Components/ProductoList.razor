@using Atlas.Shared.Configuracion
@using Atlas.Client.Services
@inject IConfiguracionApi _configuracionApi
@inject ISelectListsApi _selectListsApi;

<MudDrawer @bind-Open="@_openFilter" Fixed="false" Width="350px" Anchor="Anchor.Right" Elevation="1" Variant="@DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Filtros de búsqueda</MudText>
    </MudDrawerHeader>
    <MudDrawerContainer>
        <MudGrid Spacing="2" Class="pa-4">
            <MudItem xs="12">
                <MudSelect T="int?" Label="Periodicidad" @bind-Value="_periodicidadId" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int?" Value="0">[Seleccione]</MudSelectItem>
                    @if (_listPeriodicidad != null)
                    {
                        @foreach (var item in _listPeriodicidad)
                        {
                            <MudSelectItem T="int" Value="@Convert.ToInt32(item.Value)">@item.Text</MudSelectItem>
                        }
                    }
                </MudSelect>
         </MudItem>
            <MudItem xs="12">
                <MudButtonGroup Size="Size.Small" Variant="Variant.Filled">
                    <MudButton Color="Color.Secondary"
                               OnClick="OnCancelFilter">
                        Cancelar
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Clear"
                               OnClick="OnClearFilter"
                               Disabled="_isLoading">
                        Limpiar
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="RefreshData"
                               Disabled="_isLoading">
                        Filtrar
                    </MudButton>
                </MudButtonGroup>
            </MudItem>
        </MudGrid>
    </MudDrawerContainer>
</MudDrawer>

 

<MudDataGrid T="ProductoListItemDto"
             Outlined="true"
             Dense="true"
             Bordered="true"
             ServerData="GetTableData"
             FixedHeader="true"
             SortMode="SortMode.Single"
             @ref="_dataGridRef"
             Loading="_isLoading"
             Striped="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Listados de Productos</MudText>
        <MudSpacer />
       <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
            <MudTextField T="string"
                          ValueChanged="@(s => OnSearch(s))"
                          Placeholder="Buscar por identificador, nombre o apellido..."
                          Adornment="Adornment.Start"
                          Clearable="true"
                          Class="flex-grow-0"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Small">
            </MudTextField>
                 <MudIconButton Icon="@Icons.Material.Outlined.FilterAlt"
                           Class="align-self-end pa-1"
                           Size="Size.Medium"
                           OnClick="OnFilterClicked" /> 
        </MudStack> 
        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
          
      
            <MudTooltip Text="Actualizar">
                <MudIconButton Icon="@Icons.Material.Outlined.Refresh"
                               Size="Size.Small"
                               Color="Color.Info"
                               OnClick="RefreshData"
                               Disabled="_isLoading" />
            </MudTooltip>
            <MudTooltip Text="Agregar Cliente">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.PersonAdd"
                           OnClick="AddClick"
                           Disabled="_isLoading">
                    Nuevo Producto
                </MudButton>
            </MudTooltip>
        </MudStack>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.NomProducto" Title="Nombre" StickyLeft="true" />
        <PropertyColumn Property="x => x.Descripcion" Title="Descripción" />
        <PropertyColumn Property="x => x.Precio" Title="Precio" />
        <PropertyColumn Property="x => x.CupoMaximo" Title="Cupo Máximo" />
        <TemplateColumn Title="Acciones" CellClass="d-flex justify-end" StickyRight="true">
            <CellTemplate>
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudTooltip Text="Editar">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Title="Editar"
                                       OnClick="@(() => GoToEditProduct(context.Item.Id))" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => ConfirmDelete(context.Item))" />
                    </MudTooltip>
                </MudStack>

             
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent>
        <MudText>No se encontraron productos.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Cargando...</MudText>
    </LoadingContent>
</MudDataGrid>
@code {
    private MudDataGrid<ProductoListItemDto> _dataGridRef = null!;
    private string? _searchText;
    private int? _periodicidadId;
    private List<SelectListItemDto>? _listPeriodicidad;
    private bool _isLoading;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 10;
    private bool _openFilter;

    

    protected override async Task OnInitializedAsync()
    {
        if (_listPeriodicidad == null)
        {
            _listPeriodicidad = (await _selectListsApi.GetPeriodicidadSelectListAsync()).Data!;
        }
    }
    private async Task<GridData<ProductoListItemDto>> GetTableData(GridState<ProductoListItemDto> gridState, CancellationToken cancellationToken)
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            var _pageNumber = (gridState.Page + 1);
            var _sortBy = nameof(ProductoListItemDto.NomProducto);
            var _sortDescending = true;
            var _sortDefinitions = gridState.SortDefinitions.FirstOrDefault();
            if (_sortDefinitions != null)
            {
                _sortBy = _sortDefinitions.SortBy;
                _sortDescending = _sortDefinitions.Descending;
            }
            var paginatedList = await _configuracionApi.GetProductosAsync(_searchText,
                _pageNumber,
                gridState.PageSize, _sortBy, _sortDescending, _periodicidadId);
            return new GridData<ProductoListItemDto>()
            {
                TotalItems = paginatedList.Data!.TotalCount,
                Items = paginatedList.Data!.Results
            };
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar clientes: {ex.Message}", Severity.Error);
            return new GridData<ProductoListItemDto>() { TotalItems = 0, Items = Enumerable.Empty<ProductoListItemDto>() };
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void AddClick()
    {
        _navManager.NavigateTo(PageRoute.NewProductoPage);
    }

    private void GoToEditProduct(int id)
    {
        _navManager.NavigateTo($"{PageRoute.EditProductoPage}/{id}");
    }

    private async Task ConfirmDelete(ProductoListItemDto producto)
    {
        var confirm = await _dialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"¿Deseas eliminar el producto \"{producto.NomProducto}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar",
            cancelText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (confirm == true)
            await DeleteProducto((int)producto.Id);
    }

    private async Task DeleteProducto(int id)
    {
        // try
        // {
        //     await _configuracionApi.DeleteProductoAsync(id);
        //     _snackbarService.Add("Producto eliminado correctamente", Severity.Success);
        //     if (_productos.Count == 1 && _currentPage > 1)
        //         _currentPage--;
        //     await LoadData();
        // }
        // catch (Exception ex)
        // {
        //     _snackbarService.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        // }
    }

    private async Task RefreshData()
    {
        if (_dataGridRef != null)
        {
            await _dataGridRef.ReloadServerData();
        }
    }
    private async Task ApplyFilters()
    {
        _openFilter = false;
        await RefreshData();
    }

    private async Task OnClearFilter()
    {
        _searchText = null;
        _periodicidadId = null;
        await RefreshData();
        _openFilter = false;
    }
    private void OnFilterClicked()
    {
        _openFilter = true;
    }
    private async Task OnCancelFilter()
    {
        await RefreshData();
        _openFilter = false;
    }
    private async Task OnSearch(string? text)
    {
        _searchText = text;
        await RefreshData();
    }
}
