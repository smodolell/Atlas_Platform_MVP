@using Atlas.Shared.Configuracion
@using Atlas.Client.Clients
@inject IConfiguracionApi _configuracionApi
@inject ISnackbar _snackbarService
@inject IDialogService _dialogService
@inject NavigationManager _navigationManager

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudTextField @bind-Value="_searchQuery"
                      Placeholder="Buscar producto..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Clearable="true"
                      OnClearButtonClick="OnSearchCleared"
                      Style="max-width:320px" />
        <MudButton StartIcon="@Icons.Material.Filled.Search"
                   Variant="Variant.Filled"
                   Color="Color.Default"
                   OnClick="LoadData"
                   Size="Size.Small">
            Buscar
        </MudButton>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.AddBox"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="GoToNewProduct">
            Nuevo Producto
        </MudButton>
    </MudStack>

    <MudDataGrid T="ProductoListItemDto"
                 Items="_productos"
                 Loading="_isLoading"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 SortMode="SortMode.None">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.NomProducto" Title="Nombre" />
            <PropertyColumn Property="x => x.Descripcion" Title="Descripción" />
            <PropertyColumn Property="x => x.Precio" Title="Precio" />
            <PropertyColumn Property="x => x.CupoMaximo" Title="Cupo Máximo" />
            <TemplateColumn Title="Acciones" CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Title="Editar"
                                   OnClick="@(() => GoToEditProduct(context.Item.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Title="Eliminar"
                                   OnClick="@(() => ConfirmDelete(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>No se encontraron productos.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando...</MudText>
        </LoadingContent>
    </MudDataGrid>

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
        <MudText Typo="Typo.body2">Total: @_totalCount registros</MudText>
        <MudSpacer />
        <MudPagination Count="_totalPages"
                       Selected="_currentPage"
                       SelectedChanged="OnPageChanged"
                       Color="Color.Primary"
                       ShowFirstButton="true"
                       ShowLastButton="true" />
    </MudStack>
</MudPaper>

@code {
    private List<ProductoListItemDto> _productos = [];
    private string _searchQuery = string.Empty;
    private bool _isLoading;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var response = await _configuracionApi.GetProductosAsync(_searchQuery, _currentPage, PageSize);
            if (response.Content != null && response.Content.Data != null)
            {
                _productos = response.Content.Data.Results ?? [];
                _totalCount = response.Content.Data.TotalCount;
                _totalPages = response.Content.Data.TotalPages;
                if (_totalPages < 1) _totalPages = 1;
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar productos: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private async Task OnSearchCleared()
    {
        _searchQuery = string.Empty;
        _currentPage = 1;
        await LoadData();
    }

    private void GoToNewProduct()
    {
        _navigationManager.NavigateTo(PageRoute.NewProductoPage);
    }

    private void GoToEditProduct(int id)
    {
        _navigationManager.NavigateTo($"{PageRoute.EditProductoPage}/{id}");
    }

    private async Task ConfirmDelete(ProductoListItemDto producto)
    {
        var confirm = await _dialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"¿Deseas eliminar el producto \"{producto.NomProducto}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar",
            cancelText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (confirm == true)
            await DeleteProducto((int)producto.Id);
    }

    private async Task DeleteProducto(int id)
    {
        try
        {
            await _configuracionApi.DeleteProductoAsync(id);
            _snackbarService.Add("Producto eliminado correctamente", Severity.Success);
            if (_productos.Count == 1 && _currentPage > 1)
                _currentPage--;
            await LoadData();
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        }
    }
}
