@attribute [Route(PageRoute.NewSocioPage)]
@attribute [AccessPoint(AppMenu.MenuSocios, "Nuevo Socio")]
@using Atlas.Shared.Socios
@using Atlas.Client.Services
@using Atlas.Admin.Pages.Socios.Components

@inject ISociosApi _socioApi;

<PageHeader Title="Nuevo Socio" Icon="@Icons.Material.Filled.AddBox">
    <MudBreadcrumbs Items="_breadcrumbItems"></MudBreadcrumbs>
</PageHeader>
<MudPaper Elevation="2" Class="pa-4 mt-4">
    <SocioForm Model="_model"
                  IsSaving="_isSaving"
                  OnValidSubmit="HandleSave"
                  OnCancel="GoBack" />
</MudPaper>
@code {
    private readonly List<BreadcrumbItem> _breadcrumbItems = new()
{
        new BreadcrumbItem("Inicio", href: "/"),
        new BreadcrumbItem("Socios", href: PageRoute.SociosPage),
        new BreadcrumbItem("Nuevo Socio", href: null, disabled: true)
    };

    private SocioEditDto _model = new();
    private bool _isSaving;
    private async Task HandleSave(SocioEditDto model)
    {
        _isSaving = true;
        try
        {
            var response = await _socioApi.CreateSocioAsync(model);
            _snackbarService.Add("Socio creado correctamente", Severity.Success);
            _navManager.NavigateTo(PageRoute.SociosPage);          
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void GoBack()
    {
        _navManager.NavigateTo(PageRoute.PlanesPage);
    }
}
