@attribute [Route(PageRoute.RegistrarPagoPage)]
@attribute [AccessPoint(AppMenu.MenuSocios, "Registrar Pago")]
@using Atlas.Admin.Pages.Pagos.Components

<PageHeader Title="Registrar Pago" Icon="@Icons.Material.Filled.Payments">
    <MudBreadcrumbs Items="_breadcrumbItems"></MudBreadcrumbs>
</PageHeader>

<MudPaper Elevation="2" Class="pa-6 mt-4">
    <RegistrarPagoForm OnSuccess="HandleSuccess" OnCancel="HandleCancel" />
</MudPaper>

@code {
    private readonly List<BreadcrumbItem> _breadcrumbItems =
    [
        new BreadcrumbItem("Inicio", href: "/"),
        new BreadcrumbItem("Socios", href: PageRoute.SociosPage),
        new BreadcrumbItem("Registrar Pago", href: null, disabled: true)
    ];

    private void HandleSuccess() => _navManager.NavigateTo(PageRoute.MembresiasPage);
    private void HandleCancel() => _navManager.NavigateTo(PageRoute.SociosPage);
}
