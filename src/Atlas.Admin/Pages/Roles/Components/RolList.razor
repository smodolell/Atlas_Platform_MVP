@using Atlas.Client.Services
@using Atlas.Shared.Accounts.Roles
@inject IAccountsApi _accountsApi

<MudPaper Elevation="2" Class="pa-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudTextField @bind-Value="_searchQuery"
                      Placeholder="Buscar rol..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Clearable="true"
                      OnClearButtonClick="OnSearchCleared"
                      Style="max-width:320px" />
        <MudButton StartIcon="@Icons.Material.Filled.Search"
                   Variant="Variant.Filled"
                   Color="Color.Default"
                   OnClick="LoadData"
                   Size="Size.Small">
            Buscar
        </MudButton>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="OpenCreateDialog">
            Nuevo Rol
        </MudButton>
    </MudStack>

    <MudDataGrid T="RolListItemDto"
                 Items="_roles"
                 Loading="_isLoading"
                 Hover="true"
                 Striped="true"
                 Bordered="true"
                 Dense="true"
                 SortMode="SortMode.None">
        <Columns>
            <PropertyColumn Property="x => x.Id" Title="ID" />
            <PropertyColumn Property="x => x.Name" Title="Nombre" />
            <PropertyColumn Property="x => x.Descripcion" Title="Descripción" />
            <TemplateColumn Title="Activo" CellClass="text-center">
                <CellTemplate>
                    <MudIcon Icon="@(context.Item.IsEnabled == true ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             Color="@(context.Item.IsEnabled == true ? Color.Success : Color.Error)"
                             Size="Size.Small" />
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Acciones" CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Size="@MudBlazor.Size.Small" Icon="@Icons.Material.Outlined.Edit" Color="Color.Primary"
                                   OnClick="()=>OpenUpdateDialog(context.Item.Id)" />
                    <MudIconButton Size="@MudBlazor.Size.Small" Icon="@Icons.Material.Outlined.Menu" Color="Color.Tertiary"
                                   OnClick="()=>SetRoleMenuClick(context.Item.Id)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => ConfirmDelete(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText>No se encontraron roles.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Cargando...</MudText>
        </LoadingContent>
    </MudDataGrid>

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
        <MudText Typo="Typo.body2">Total: @_totalCount registros</MudText>
        <MudSpacer />
        <MudPagination Count="_totalPages"
                       Selected="_currentPage"
                       SelectedChanged="OnPageChanged"
                       Color="Color.Primary"
                       ShowFirstButton="true"
                       ShowLastButton="true" />
    </MudStack>
</MudPaper>

@code {
    private List<RolListItemDto> _roles = [];
    private string _searchQuery = string.Empty;
    private bool _isLoading;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var response = await _accountsApi.GetRoles(_searchQuery, _currentPage, PageSize);
            
            if (response?.Data != null)
            {
                _roles = response.Data.Results ?? [];
                _totalCount = response.Data.TotalCount;
                _totalPages = response.Data.TotalPages;
                if (_totalPages < 1) _totalPages = 1;
            }
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al cargar roles: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadData();
    }

    private async Task OnSearchCleared()
    {
        _searchQuery = string.Empty;
        _currentPage = 1;
        await LoadData();
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await _dialogService.ShowAsync<RolFormDialog>("Nuevo Rol", new DialogParameters(), new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        });
        var result = await dialog.Result;
        if (!result!.Canceled) await LoadData();
    }
    private async Task OpenUpdateDialog(int id)
    {
        var parameters = new DialogParameters
        {
            {"RolId",id }
        };
        var dialog = await _dialogService.ShowAsync<RolFormDialog>("Nuevo Rol", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        });
        var result = await dialog.Result;
        if (!result!.Canceled) await LoadData();
    }

    private async Task ConfirmDelete(RolListItemDto rol)
    {
        var confirm = await _dialogService.ShowMessageBoxAsync(
            "Confirmar eliminación",
            $"¿Deseas eliminar el rol \"{rol.Name}\"? Esta acción no se puede deshacer.",
            yesText: "Eliminar",
            cancelText: "Cancelar",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if (confirm == true)
            await DeleteRol(rol.Id);
    }

    private async Task DeleteRol(int id)
    {
        try
        {
            // await _accountsApi.Deleter Async();
            _snackbarService.Add("Rol eliminado correctamente", Severity.Success);
            if (_roles.Count == 1 && _currentPage > 1)
                _currentPage--;
            await LoadData();
        }
        catch (Exception ex)
        {
            _snackbarService.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        }
    }

    private async Task SetRoleMenuClick(int roleId)
    {

        var parameters = new DialogParameters
{
            {"RolId",roleId }
        };
        var options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await _dialogService.ShowAsync<RolAccessPointFormDialog>("Rol -> Punto de Acceso", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            await LoadData();
        }

    }

}
