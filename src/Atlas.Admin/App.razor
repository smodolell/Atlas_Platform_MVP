
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="AdditionalAssemblies">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @* Aquí puedes poner un mensaje o redirigir al Login *@
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="ma-4">
                        No tienes permisos para acceder a esta sección.
                    </MudAlert>
                </NotAuthorized>
                <Authorizing>
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudText Typo="Typo.h3">Página no encontrada</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
